@model CoachingWebsite.Models.Teacher

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-5">

            <div class="card shadow p-5 text-center">

                <h2 class="mb-4 text-primary">
                    Teacher Details
                </h2>

                <h3>
                    @Model.Name
                </h3>

                <h4 class="text-success mt-3">
                    @Model.Subject
                </h4>

                <h5 class="mt-3">
                    @Model.Email
                </h5>

            </div>

        </div>

    </div>

</div>