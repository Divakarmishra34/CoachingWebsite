@{
    ViewData["Title"] = "About";
}

<div class="container mt-5">

    <!-- HEADER -->

    <div class="bg-dark text-white p-5 rounded-4 shadow-lg text-center">

        <h1 class="display-4 fw-bold text-warning">

            About Our Coaching Institute

        </h1>

        <p class="lead mt-3">

            We provide quality education
            with expert teachers and modern learning.

        </p>

    </div>


    <!-- ABOUT SECTION -->

    <div class="row mt-5 align-items-center">

        <div class="col-md-6">

            <img src="/images/coaching.jpg"
                 class="img-fluid rounded-4 shadow" />

        </div>


        <div class="col-md-6">

            <h2 class="fw-bold">
                Who We Are?
            </h2>

            <p class="mt-3">

                Our coaching institute helps students
                achieve success in Maths, Science
                and English subjects.

            </p>

            <p>

                We focus on quality education,
                weekly tests and best results.

            </p>

        </div>

    </div>


    <!-- FEATURES -->

    <div class="row mt-5 text-center">

        <div class="col-md-4 mb-4">

            <div class="card p-4 shadow border-0 rounded-4">

                <h1>
                    👨‍🏫
                </h1>

                <h3 class="mt-3">
                    Expert Teachers
                </h3>

                <p>
                    Highly experienced teachers
                    for all subjects.
                </p>

            </div>

        </div>


        <div class="col-md-4 mb-4">

            <div class="card p-4 shadow border-0 rounded-4">

                <h1>
                    📚
                </h1>

                <h3 class="mt-3">
                    Smart Learning
                </h3>

                <p>
                    Modern teaching methods
                    and study materials.
                </p>

            </div>

        </div>


        <div class="col-md-4 mb-4">

            <div class="card p-4 shadow border-0 rounded-4">

                <h1>
                    🏆
                </h1>

                <h3 class="mt-3">
                    Best Results
                </h3>

                <p>
                    Excellent student performance
                    every year.
                </p>

            </div>

        </div>

    </div>

</div>