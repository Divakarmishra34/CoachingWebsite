@{
    ViewData["Title"] = "Home";
}

<div class="container mt-5">

    <!-- HERO SECTION -->

    <div class="bg-dark text-white p-5 rounded-4 shadow-lg text-center">

        <h1 class="display-3 fw-bold text-warning">

            Welcome To Coaching Institute

        </h1>

        <p class="lead mt-4">

            Best coaching classes for Maths,
            Science and English 🚀

        </p>

        <a href="/Student/Register"
           class="btn btn-warning btn-lg mt-3 me-2">

            Register Now

        </a>

        <a href="/Dashboard"
           class="btn btn-outline-light btn-lg mt-3">

            Open Dashboard

        </a>

    </div>


    <!-- Teacher Section -->

    <div class="mt-5">

        <h2 class="text-center mb-4">
            Our Expert Teachers
        </h2>

        <div class="row">

            <div class="col-md-4">
                <div class="card p-3 text-center shadow-lg border-0 rounded-4">

                    <img src="/images/maths.jpg"
                         class="rounded-circle mx-auto"
                         width="150"
                         height="150" />

                    <h4 class="mt-3">
                        Rajesh Sir
                    </h4>

                    <p>
                        Maths Expert
                    </p>

                </div>
            </div>

            <div class="col-md-4">
                <div class="card p-3 text-center shadow-lg border-0 rounded-4">

                    <img src="/images/science.jpg"
                         class="rounded-circle mx-auto"
                         width="150"
                         height="150" />

                    <h4 class="mt-3">
                        Anita Ma'am
                    </h4>

                    <p>
                        Science Expert
                    </p>

                </div>
            </div>

            <div class="col-md-4">
                <div class="card p-3 text-center shadow-lg border-0 rounded-4">

                    <img src="/images/english.jpg"
                         class="rounded-circle mx-auto"
                         width="150"
                         height="150" />

                    <h4 class="mt-3">
                        Amit Sir
                    </h4>

                    <p>
                        English Expert
                    </p>

                </div>
            </div>

        </div>

    </div>

    <!-- Notice Board -->

    <div class="mt-5">

        <div class="alert alert-warning shadow">

            <h3>
                Latest Notices
            </h3>

            <ul class="mb-0">

                <li>
                    New batch starts from 15 June
                </li>

                <li>
                    Weekly test every Sunday
                </li>

                <li>
                    Scholarship test registration open
                </li>

            </ul>

        </div>

    </div>

    <!-- FAQ Section -->

    <div class="mt-5">

        <h2 class="text-center mb-4">
            Frequently Asked Questions
        </h2>

        <div class="accordion" id="faqAccordion">

            <div class="accordion-item">

                <h2 class="accordion-header">

                    <button class="accordion-button"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#faq1">

                        What courses do you provide?

                    </button>

                </h2>

                <div id="faq1"
                     class="accordion-collapse collapse show">

                    <div class="accordion-body">

                        We provide Maths, Science and English courses.

                    </div>

                </div>

            </div>

            <div class="accordion-item">

                <h2 class="accordion-header">

                    <button class="accordion-button collapsed"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#faq2">

                        Do you provide weekly tests?

                    </button>

                </h2>

                <div id="faq2"
                     class="accordion-collapse collapse">

                    <div class="accordion-body">

                        Yes, weekly tests are conducted every Sunday.

                    </div>

                </div>

            </div>

        </div>

    </div>

    <!-- Call To Action -->

    <div class="text-center mt-5">

        <h2>
            Join Our Coaching Today
        </h2>

        <a href="/Student/Register"
           class="btn btn-success mt-3">
            Register Now
        </a>

    </div>

    <!-- Stats Section -->

    <div class="row text-center mt-5">

        <div class="col-md-4">

            <h1>
                500+
            </h1>

            <p>
                Students
            </p>

        </div>

        <div class="col-md-4">

            <h1>
                20+
            </h1>

            <p>
                Courses
            </p>

        </div>

        <div class="col-md-4">

            <h1>
                10+
            </h1>

            <p>
                Teachers
            </p>

        </div>

    </div>

    <!-- Why Choose Us -->

    <div class="text-center mt-5">

        <h2>
            Why Choose Us?
        </h2>

    </div>

    <div class="row mt-4 text-center">

        <div class="col-md-4">

            <div class="card p-4 shadow">

                <h3>
                    Expert Teachers
                </h3>

                <p>
                    Experienced faculty for all subjects.
                </p>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card p-4 shadow">

                <h3>
                    Weekly Tests
                </h3>

                <p>
                    Regular practice and mock tests.
                </p>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card p-4 shadow">

                <h3>
                    Best Results
                </h3>

                <p>
                    Excellent student performance every year.
                </p>

            </div>

        </div>

    </div>

    <!-- Top Courses -->

    <div class="mt-5 text-center">

        <h2>
            Our Top Courses
        </h2>

    </div>

    <div class="row mt-4">

        <div class="col-md-4">

            <div class="card p-3 text-center shadow">

                <h3>
                    Maths
                </h3>

                <p>
                    Complete maths preparation.
                </p>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card p-3 text-center shadow">

                <h3>
                    Science
                </h3>

                <p>
                    Physics, Chemistry and Biology.
                </p>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card p-3 text-center shadow">

                <h3>
                    English
                </h3>

                <p>
                    Grammar and spoken English.
                </p>

            </div>

        </div>

    </div>

    <!-- Brochure Section -->

    <div class="text-center mt-5">

        <h2>
            Download Our Brochure
        </h2>

        <a href="#"
           class="btn btn-danger mt-3">
            Download PDF
        </a>

    </div>

    <!-- Student Reviews -->

    <div class="mt-5 text-center">

        <h2>
            Student Reviews
        </h2>

    </div>

    <div class="row mt-4">

        <div class="col-md-4">
            <div class="card p-3 shadow">

                <p>
                    Best coaching institute with supportive teachers.
                </p>

                <h5>
                    - Rahul
                </h5>

            </div>
        </div>

        <div class="col-md-4">
            <div class="card p-3 shadow">

                <p>
                    Very good classes and excellent study material.
                </p>

                <h5>
                    - Priya
                </h5>

            </div>
        </div>

        <div class="col-md-4">
            <div class="card p-3 shadow">

                <p>
                    Helped me score high marks in exams.
                </p>

                <h5>
                    - Aman
                </h5>

            </div>
        </div>

    </div>

</div>