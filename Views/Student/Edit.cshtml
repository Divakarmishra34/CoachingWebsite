@model CoachingWebsite.Models.Student

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-6">

            <div class="card p-4">

                <h2 class="text-center mb-4">
                    Edit Student
                </h2>

                <form method="post">

                    <input type="hidden"
                           asp-for="Id" />

                    <div class="mb-3">

                        <label>Name</label>

                        <input asp-for="Name"
                               class="form-control" />

                    </div>

                    <div class="mb-3">

                        <label>Email</label>

                        <input asp-for="Email"
                               class="form-control" />

                    </div>

                    <div class="mb-3">

                        <label>Course</label>

                        <input asp-for="Course"
                               class="form-control" />

                    </div>
<div class="mb-3 form-check">

    <input asp-for="IsPresent"
           class="form-check-input" />

    <label class="form-check-label">
        Present
    </label>

</div>
<div class="mb-3 form-check">

    <input asp-for="FeesPaid"
           class="form-check-input" />

    <label class="form-check-label">
        Fees Paid
    </label>

</div>
                    <button class="btn btn-success w-100">
                        Update Student
                    </button>

                </form>

            </div>

        </div>

    </div>

</div>