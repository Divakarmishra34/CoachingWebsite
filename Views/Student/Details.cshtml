@model CoachingWebsite.Models.Student

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-6">

            <div class="card shadow p-5 text-center">

                <img src="@Model.ImagePath"
                     width="150"
                     height="150"
                     style="border-radius:50%;
                            object-fit:cover;
                            margin:auto;" />

                <h2 class="mt-4">
                    @Model.Name
                </h2>

                <h4 class="text-muted">
                    @Model.Email
                </h4>

                <h3 class="mt-3 text-primary">
                    @Model.Course
                </h3>

            </div>

        </div>

    </div>

</div>