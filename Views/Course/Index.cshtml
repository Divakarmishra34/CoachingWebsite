@{
    ViewData["Title"] = "Courses";
}

<div class="container mt-5">

    <div class="text-center mb-5">

        <h1 class="fw-bold">
            Our Courses
        </h1>

        <p class="mt-3">
            Best coaching courses for students 🚀
        </p>

    </div>


    <div class="row">

        <!-- Maths -->

        <div class="col-md-4 mb-4">

            <div class="card shadow-lg border-0 rounded-4 text-center p-4">

                <img src="/images/maths.jpg"
                     class="rounded mx-auto"
                     width="100%"
                     height="220" />

                <h2 class="mt-4">
                    Maths
                </h2>

                <p class="mt-3">

                    Complete maths preparation
                    with expert teachers.

                </p>

                <a href="/Student/Register"
                   class="btn btn-primary">

                    Join Now

                </a>

            </div>

        </div>


        <!-- Science -->

        <div class="col-md-4 mb-4">

            <div class="card shadow-lg border-0 rounded-4 text-center p-4">

                <img src="/images/science.jpg"
                     class="rounded mx-auto"
                     width="100%"
                     height="220" />

                <h2 class="mt-4">
                    Science
                </h2>

                <p class="mt-3">

                    Physics, Chemistry and Biology
                    classes with practical learning.

                </p>

                <a href="/Student/Register"
                   class="btn btn-success">

                    Join Now

                </a>

            </div>

        </div>


        <!-- English -->

        <div class="col-md-4 mb-4">

            <div class="card shadow-lg border-0 rounded-4 text-center p-4">

                <img src="/images/english.jpg"
                     class="rounded mx-auto"
                     width="100%"
                     height="220" />

                <h2 class="mt-4">
                    English
                </h2>

                <p class="mt-3">

                    Spoken English, grammar
                    and communication skills.

                </p>

                <a href="/Student/Register"
                   class="btn btn-danger">

                    Join Now

                </a>

            </div>

        </div>

    </div>

</div>